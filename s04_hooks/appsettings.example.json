{
  "modelId": "deepseek-v4-flash",
  "baseUrl": "https://api.deepseek.com/anthropic",
  "apiKey": "PUT-YOUR-KEY-HERE",
  "maxTokens": 8000,

  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "node hooks/log-prompt.js" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "bash",
        "hooks": [
          { "type": "command", "command": "node hooks/block-rm.js" }
        ]
      },
      {
        "matcher": "write_file|edit_file",
        "hooks": [
          { "type": "command", "command": "node hooks/path-guard.js" }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "node hooks/log-pretool.js" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          { "type": "command", "command": "node hooks/large-output.js" }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "node hooks/audit-log.js" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "npx tsx hooks/summary.ts" }
        ]
      }
    ]
  }
}
